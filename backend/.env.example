# Knowledge Nexus 环境变量配置
# 复制为 .env 并填入实际值

# 数据库（开发阶段使用 SQLite，无需配置）
# DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/knowledge_nexus

# Neo4j（可选，不配置则跳过图谱功能）
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=nexus_graph

# AI / LLM（可选）
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1

# Semantic Scholar API（可选，有 key 可提升限流）
# SEMANTIC_SCHOLAR_API_KEY=

# 爬虫配置
CRAWLER_RATE_LIMIT=1.5
CRAWLER_MAX_RETRIES=3
